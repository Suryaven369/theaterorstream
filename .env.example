# Supabase — client (safe to expose via VITE_ prefix)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase — server only (required for local admin sync: npm run dev)
# Copy to .env.local — NEVER commit, NEVER use VITE_ prefix for service role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional; defaults to VITE_SUPABASE_URL if omitted
# SUPABASE_URL=https://your-project.supabase.co

# TMDB (server-side only — set in Vercel, NOT with VITE_ prefix)
# Use ONE of these from https://www.themoviedb.org/settings/api :
#
# Option A — API Key (v3, 32-char hex): set TMDB_API_KEY
# Option B — API Read Access Token (v4, starts with eyJ): set TMDB_ACCESS_TOKEN
#
TMDB_API_KEY=your_tmdb_v3_api_key
# TMDB_ACCESS_TOKEN=your_tmdb_v4_read_access_token

# Optional: local admin dev fallback when /api/tmdb proxy is unavailable (vite dev only)
# VITE_MOVIE_API_KEY=your_tmdb_v3_api_key_or_v4_token

# Cron sync (server-side only — required for automated TMDB ingestion + local admin sync)
CRON_SECRET=your_random_cron_secret

# Taste embeddings (server-side only — Task #10 profile rebuild + movie backfill)
# Provider priority: VOYAGE > GEMINI > HF > OPENAI. Gemini (free) reuses
# GEMINI_API_KEY below and outputs 512-dim vectors (matches the DB column).
# GEMINI_EMBED_MODEL=gemini-embedding-001
# Free tier option: Hugging Face Inference API
HF_API_KEY=your_huggingface_token
# HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Paid fallbacks:
VOYAGE_API_KEY=your_voyage_api_key
# OPENAI_API_KEY=your_openai_api_key

# LLM re-ranking + taste summaries (server-side only — OPTIONAL).
# Free tier: Google AI Studio key — https://aistudio.google.com/apikey (starts with "AIza").
# If unset, the rule-based engine runs exactly as before (graceful fallback).
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash
# Mistral — automatic fallback when Gemini is missing / rate-limited.
# MIST_API_KEY=your_mistral_api_key
# MISTRAL_MODEL=mistral-small-latest

# Real-time trailer PUSH via WebSub (PubSubHubbub) — server-side only.
# PUBLIC_BASE_URL is your deployed site origin; YouTube's hub POSTs trailer
# uploads to <PUBLIC_BASE_URL>/api/websub the instant a channel publishes.
# WEBSUB_SECRET (any random string) signs hub notifications — recommended.
# PUBLIC_BASE_URL=https://your-app.vercel.app
# WEBSUB_SECRET=your_random_websub_secret

# Admin security (optional)
# Comma-separated IP addresses or CIDR ranges allowed for admin access
# Leave empty to allow all IPs
# ADMIN_IP_WHITELIST=192.168.1.0/24,10.0.0.1

# Rate limiting (optional, defaults shown)
# ADMIN_RATE_LIMIT_READS=100
# ADMIN_RATE_LIMIT_WRITES=30
