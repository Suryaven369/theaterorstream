{
    "crons": [
        {
            "path": "/api/cron/trending-daily",
            "schedule": "0 6 * * *"
        },
        {
            "path": "/api/cron/now-playing-daily",
            "schedule": "30 6 * * *"
        },
        {
            "path": "/api/cron/upcoming-weekly",
            "schedule": "0 7 * * 5"
        },
        {
            "path": "/api/cron/popular-weekly",
            "schedule": "0 8 * * 1"
        },
        {
            "path": "/api/cron/top-rated-monthly",
            "schedule": "0 9 1 * *"
        },
        {
            "path": "/api/cron/new-releases-weekly",
            "schedule": "0 10 * * 3"
        },
        {
            "path": "/api/cron/taste-profile-weekly",
            "schedule": "0 4 * * 0"
        },
        {
            "path": "/api/cron/embedding-backfill",
            "schedule": "0 5 * * 0"
        },
        {
            "path": "/api/cron/rss-refresh",
            "schedule": "0 11 * * *"
        },
        {
            "path": "/api/cron/websub-renew",
            "schedule": "0 3 * * *"
        },
        {
            "path": "/api/cron/news-pipeline",
            "schedule": "0 8 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap.xml"
        },
        {
            "source": "/sitemap-pages.xml",
            "destination": "/api/sitemap-pages.xml"
        },
        {
            "source": "/sitemap-movies.xml",
            "destination": "/api/sitemap-movies.xml"
        },
        {
            "source": "/sitemap-lists.xml",
            "destination": "/api/sitemap-lists.xml"
        },
        {
            "source": "/sitemap-community.xml",
            "destination": "/api/sitemap-community.xml"
        },
        {
            "source": "/api/tmdb/(.*)",
            "destination": "/api/tmdb?path=$1"
        },
        {
            "source": "/((?!api|_next/static|_next/image|favicon.ico|robots.txt|llms.txt|sitemap.*\\.xml|.*\\..*$).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=63072000; includeSubDomains; preload"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}