{
    "crons": [
        {
            "path": "/api/cron/trending-daily",
            "schedule": "0 6 * * 5"
        },
        {
            "path": "/api/cron/now-playing-daily",
            "schedule": "30 6 * * 5"
        },
        {
            "path": "/api/cron/upcoming-weekly",
            "schedule": "0 7 * * 5"
        },
        {
            "path": "/api/cron/taste-profile-weekly",
            "schedule": "0 4 * * 0"
        },
        {
            "path": "/api/cron/embedding-backfill",
            "schedule": "0 5 * * 0"
        }
    ],
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap.xml"
        },
        {
            "source": "/api/tmdb/(.*)",
            "destination": "/api/tmdb?path=$1"
        },
        {
            "source": "/((?!api|_next/static|_next/image|favicon.ico|robots.txt|.*\\..*$).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}